<?xml version="1.0" encoding="utf-8" ?>
<views:ThumpView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:views="clr-namespace:Thump.Views"
                 x:Class="Thump.Views.NowPlayingView"
                 BackgroundColor="#0a0a0c">

	<Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto">

		<HorizontalStackLayout Grid.Row="0" Padding="8,8,8,0">
			<Button Text="‹"
			        FontSize="22"
			        TextColor="#e8e8ec"
			        BackgroundColor="Transparent"
			        WidthRequest="44"
			        HeightRequest="44"
			        Clicked="OnBackClicked" />
		</HorizontalStackLayout>

		<views:ArtImage x:Name="m_art"
		                Grid.Row="1"
		                WidthRequest="280"
		                HeightRequest="280"
		                HorizontalOptions="Center"
		                VerticalOptions="Center" />

		<StackLayout Grid.Row="2" Spacing="4" Padding="24,16,24,8">
			<Label x:Name="m_titleLabel"
			       Text="Track title"
			       FontSize="20"
			       TextColor="#e8e8ec"
			       HorizontalOptions="Center"
			       LineBreakMode="TailTruncation" />
			<Label x:Name="m_artistLabel"
			       Text="Artist"
			       FontSize="14"
			       TextColor="#8888a0"
			       HorizontalOptions="Center"
			       LineBreakMode="TailTruncation" />
		</StackLayout>

		<Grid Grid.Row="3" Padding="24,8,24,4" ColumnDefinitions="Auto,*,Auto">
			<Label Grid.Column="0"
			       x:Name="m_currentTimeLabel"
			       Text="0:00"
			       FontSize="11"
			       TextColor="#555568"
			       VerticalOptions="Center" />
			<Slider Grid.Column="1"
			        x:Name="m_seekSlider"
			        Minimum="0"
			        Maximum="100"
			        Value="0"
			        MinimumTrackColor="#3b82f6"
			        MaximumTrackColor="#1e1e24"
			        ThumbColor="#3b82f6" />
			<Label Grid.Column="2"
			       x:Name="m_totalTimeLabel"
			       Text="0:00"
			       FontSize="11"
			       TextColor="#555568"
			       VerticalOptions="Center" />
		</Grid>

		<HorizontalStackLayout Grid.Row="4" Spacing="16" HorizontalOptions="Center" Padding="0,8,0,8">
			<Button Text="⇋"
			        FontSize="20"
			        TextColor="#8888a0"
			        BackgroundColor="Transparent"
			        WidthRequest="48"
			        HeightRequest="48"
			        Clicked="OnShuffleClicked" />
			<Button Text="⏮"
			        FontSize="22"
			        TextColor="#e8e8ec"
			        BackgroundColor="Transparent"
			        WidthRequest="56"
			        HeightRequest="56"
			        Clicked="OnPrevClicked" />
			<Button x:Name="m_playPauseButton"
			        Text="▶"
			        FontSize="26"
			        TextColor="#0a0a0c"
			        BackgroundColor="#3b82f6"
			        CornerRadius="32"
			        WidthRequest="64"
			        HeightRequest="64"
			        Clicked="OnPlayPauseClicked" />
			<Button Text="⏭"
			        FontSize="22"
			        TextColor="#e8e8ec"
			        BackgroundColor="Transparent"
			        WidthRequest="56"
			        HeightRequest="56"
			        Clicked="OnNextClicked" />
			<Button Text="↻"
			        FontSize="20"
			        TextColor="#8888a0"
			        BackgroundColor="Transparent"
			        WidthRequest="48"
			        HeightRequest="48"
			        Clicked="OnRepeatClicked" />
		</HorizontalStackLayout>

		<HorizontalStackLayout Grid.Row="5" Spacing="16" HorizontalOptions="Center" Padding="0,0,0,16">
			<Button Text="♡  Favorite"
			        TextColor="#8888a0"
			        BackgroundColor="Transparent"
			        FontSize="13"
			        Clicked="OnFavoriteClicked" />
			<Button Text="≣  Queue"
			        TextColor="#8888a0"
			        BackgroundColor="Transparent"
			        FontSize="13"
			        Clicked="OnQueueClicked" />
		</HorizontalStackLayout>

	</Grid>

</views:ThumpView>
