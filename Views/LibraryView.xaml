<?xml version="1.0" encoding="utf-8" ?>
<views:ThumpView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:views="clr-namespace:Thump.Views"
                 xmlns:tiles="clr-namespace:Thump.Views.Tiles"
                 x:Class="Thump.Views.LibraryView"
                 BackgroundColor="#0a0a0c">

	<Grid RowDefinitions="Auto,Auto,*">

		<Label Grid.Row="0"
		       Text="Library"
		       FontSize="24"
		       TextColor="#e8e8ec"
		       Padding="16,12" />

		<HorizontalStackLayout Grid.Row="1" Spacing="8" Padding="16,0,16,12">
			<Button x:Name="m_chipArtists"
			        Text="Artists"
			        TextColor="#0a0a0c"
			        BackgroundColor="#3b82f6"
			        CornerRadius="16"
			        FontSize="13"
			        Padding="14,4"
			        HeightRequest="32"
			        Clicked="OnChipArtistsClicked" />
			<Button x:Name="m_chipAlbums"
			        Text="Albums"
			        TextColor="#e8e8ec"
			        BackgroundColor="#101014"
			        CornerRadius="16"
			        FontSize="13"
			        Padding="14,4"
			        HeightRequest="32"
			        Clicked="OnChipAlbumsClicked" />
			<Button x:Name="m_chipPlaylists"
			        Text="Playlists"
			        TextColor="#e8e8ec"
			        BackgroundColor="#101014"
			        CornerRadius="16"
			        FontSize="13"
			        Padding="14,4"
			        HeightRequest="32"
			        Clicked="OnChipPlaylistsClicked" />
			<Button x:Name="m_chipGenres"
			        Text="Genres"
			        TextColor="#e8e8ec"
			        BackgroundColor="#101014"
			        CornerRadius="16"
			        FontSize="13"
			        Padding="14,4"
			        HeightRequest="32"
			        Clicked="OnChipGenresClicked" />
		</HorizontalStackLayout>

		<CollectionView x:Name="m_artistsList"
		                Grid.Row="2"
		                IsVisible="True"
		                BackgroundColor="#0a0a0c">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<tiles:ArtistRowTile />
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

		<CollectionView x:Name="m_albumsList"
		                Grid.Row="2"
		                IsVisible="False"
		                BackgroundColor="#0a0a0c">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<tiles:AlbumRowTile />
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

		<CollectionView x:Name="m_playlistsList"
		                Grid.Row="2"
		                IsVisible="False"
		                BackgroundColor="#0a0a0c">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<tiles:PlaylistRowTile />
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

		<CollectionView x:Name="m_genresList"
		                Grid.Row="2"
		                IsVisible="False"
		                BackgroundColor="#0a0a0c">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<tiles:GenreRowTile />
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

	</Grid>

</views:ThumpView>
