<?xml version="1.0" encoding="utf-8" ?>
<views:ThumpView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:views="clr-namespace:Thump.Views"
                 x:Class="Thump.Views.MiniPlayer"
                 BackgroundColor="#101014"
                 HeightRequest="64">

	<Grid ColumnDefinitions="64,*,Auto" Padding="8,0">
		<views:ArtImage x:Name="m_art"
		                Grid.Column="0"
		                WidthRequest="48"
		                HeightRequest="48"
		                VerticalOptions="Center" />

		<StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
			<Label x:Name="m_titleLabel"
			       Text="Nothing playing"
			       TextColor="#e8e8ec"
			       FontSize="14" />
			<Label x:Name="m_artistLabel"
			       Text=""
			       TextColor="#8888a0"
			       FontSize="12" />
		</StackLayout>

		<Button Grid.Column="2"
		        Text="▶"
		        TextColor="#e8e8ec"
		        BackgroundColor="Transparent"
		        FontSize="20"
		        WidthRequest="48"
		        HeightRequest="48"
		        Clicked="OnPlayPauseClicked" />

		<Grid.GestureRecognizers>
			<TapGestureRecognizer Tapped="OnExpandTapped" />
		</Grid.GestureRecognizers>
	</Grid>

</views:ThumpView>
