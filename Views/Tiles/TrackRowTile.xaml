<?xml version="1.0" encoding="utf-8" ?>
<views:ThumpView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:views="clr-namespace:Thump.Views"
                 x:Class="Thump.Views.Tiles.TrackRowTile">

	<Grid Padding="16,8" ColumnDefinitions="*,Auto">
		<StackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
			<Label x:Name="m_titleLabel"
			       Text="Track title"
			       TextColor="#e8e8ec"
			       FontSize="15"
			       LineBreakMode="TailTruncation" />
			<Label x:Name="m_artistLabel"
			       Text="Artist"
			       TextColor="#8888a0"
			       FontSize="12"
			       LineBreakMode="TailTruncation" />
		</StackLayout>
		<Label x:Name="m_durationLabel"
		       Grid.Column="1"
		       Text="0:00"
		       TextColor="#555568"
		       FontSize="12"
		       VerticalOptions="Center" />
		<Grid.GestureRecognizers>
			<TapGestureRecognizer Tapped="OnTapped" />
		</Grid.GestureRecognizers>
	</Grid>

</views:ThumpView>
