<?xml version="1.0" encoding="utf-8" ?>
<views:ThumpView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:views="clr-namespace:Thump.Views"
                 x:Class="Thump.Views.ArtImage">

	<Border x:Name="m_border"
	        StrokeThickness="0"
	        BackgroundColor="#2a2a32"
	        StrokeShape="RoundRectangle 6">
		<Image x:Name="m_image"
		       Aspect="AspectFill"
		       IsVisible="False" />
	</Border>

</views:ThumpView>
