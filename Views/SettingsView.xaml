<?xml version="1.0" encoding="utf-8" ?>
<views:ThumpView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:views="clr-namespace:Thump.Views"
                 x:Class="Thump.Views.SettingsView"
                 BackgroundColor="#0a0a0c">

	<ScrollView>
		<StackLayout Spacing="16" Padding="16,12">

			<Label Text="Settings"
			       FontSize="24"
			       TextColor="#e8e8ec" />

			<Label Text="Server URL"
			       FontSize="13"
			       TextColor="#8888a0"
			       Padding="0,8,0,0" />
			<Entry x:Name="m_serverUrlEntry"
			       Text="https://192.168.5.5:32458"
			       TextColor="#e8e8ec"
			       BackgroundColor="#101014"
			       FontSize="15" />

			<Label Text="Username"
			       FontSize="13"
			       TextColor="#8888a0"
			       Padding="0,8,0,0" />
			<Entry x:Name="m_usernameEntry"
			       Text="Rob"
			       TextColor="#e8e8ec"
			       BackgroundColor="#101014"
			       FontSize="15" />

			<Label Text="Password"
			       FontSize="13"
			       TextColor="#8888a0"
			       Padding="0,8,0,0" />
			<Entry x:Name="m_passwordEntry"
			       IsPassword="True"
			       TextColor="#e8e8ec"
			       BackgroundColor="#101014"
			       FontSize="15" />

			<Label Text="Prefetch limit"
			       FontSize="13"
			       TextColor="#8888a0"
			       Padding="0,16,0,0" />
			<Entry x:Name="m_prefetchEntry"
			       Text="10"
			       Keyboard="Numeric"
			       TextColor="#e8e8ec"
			       BackgroundColor="#101014"
			       FontSize="15" />

			<Label Text="Audio cache size (MB)"
			       FontSize="13"
			       TextColor="#8888a0"
			       Padding="0,8,0,0" />
			<Entry x:Name="m_cacheSizeEntry"
			       Text="500"
			       Keyboard="Numeric"
			       TextColor="#e8e8ec"
			       BackgroundColor="#101014"
			       FontSize="15" />

			<HorizontalStackLayout Spacing="12" Padding="0,12,0,0">
				<Label Text="Scrobble"
				       TextColor="#e8e8ec"
				       FontSize="15"
				       VerticalOptions="Center" />
				<Switch x:Name="m_scrobbleSwitch"
				        IsToggled="True" />
			</HorizontalStackLayout>

			<Button Text="Save"
			        TextColor="#0a0a0c"
			        BackgroundColor="#3b82f6"
			        CornerRadius="8"
			        FontSize="15"
			        HeightRequest="44"
			        Margin="0,16,0,0"
			        Clicked="OnSaveClicked" />

			<Button Text="Clear cache"
			        TextColor="#e8e8ec"
			        BackgroundColor="#101014"
			        CornerRadius="8"
			        FontSize="15"
			        HeightRequest="44"
			        Clicked="OnClearCacheClicked" />

		</StackLayout>
	</ScrollView>

</views:ThumpView>
