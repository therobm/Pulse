<?xml version="1.0" encoding="utf-8" ?>
<views:ThumpView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:views="clr-namespace:Thump.Views"
                 x:Class="Thump.Views.Tiles.HomeCarouselTile"
                 WidthRequest="140">

	<StackLayout Spacing="6" Padding="6,0">
		<views:ArtImage x:Name="m_art"
		                WidthRequest="128"
		                HeightRequest="128" />
		<Label x:Name="m_titleLabel"
		       Text="Title"
		       TextColor="#e8e8ec"
		       FontSize="13"
		       LineBreakMode="TailTruncation"
		       MaxLines="1" />
		<Label x:Name="m_subtitleLabel"
		       Text="Subtitle"
		       TextColor="#8888a0"
		       FontSize="11"
		       LineBreakMode="TailTruncation"
		       MaxLines="1" />
		<StackLayout.GestureRecognizers>
			<TapGestureRecognizer Tapped="OnTapped" />
		</StackLayout.GestureRecognizers>
	</StackLayout>

</views:ThumpView>
