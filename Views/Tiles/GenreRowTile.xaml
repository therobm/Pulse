<?xml version="1.0" encoding="utf-8" ?>
<views:ThumpView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:views="clr-namespace:Thump.Views"
                 x:Class="Thump.Views.Tiles.GenreRowTile">

	<Grid Padding="16,8" ColumnDefinitions="56,*">
		<BoxView Grid.Column="0"
		         WidthRequest="56"
		         HeightRequest="56"
		         CornerRadius="6"
		         Color="#2a2a32"
		         VerticalOptions="Center" />
		<StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2" Padding="12,0,0,0">
			<Label x:Name="m_nameLabel"
			       Text="Genre"
			       TextColor="#e8e8ec"
			       FontSize="16"
			       LineBreakMode="TailTruncation" />
			<Label x:Name="m_subtitleLabel"
			       Text=""
			       TextColor="#8888a0"
			       FontSize="12"
			       LineBreakMode="TailTruncation" />
		</StackLayout>
		<Grid.GestureRecognizers>
			<TapGestureRecognizer Tapped="OnTapped" />
		</Grid.GestureRecognizers>
	</Grid>

</views:ThumpView>
